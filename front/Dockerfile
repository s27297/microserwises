# ===== BUILD =====
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci
ARG NEXT_PUBLIC_KEYCLOAK_URL
ARG NEXT_PUBLIC_KEYCLOAK_REALM
ARG NEXT_PUBLIC_KEYCLOAK_CLIENT_ID
ENV NEXT_PUBLIC_KEYCLOAK_URL=$NEXT_PUBLIC_KEYCLOAK_URL
ENV NEXT_PUBLIC_KEYCLOAK_REALM=$NEXT_PUBLIC_KEYCLOAK_REALM
ENV NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=$NEXT_PUBLIC_KEYCLOAK_CLIENT_ID
ARG NEXT_PUBLIC_POSTS_URI
ENV NEXT_PUBLIC_POSTS_URI=$NEXT_PUBLIC_POSTS_URI

ARG NEXT_PUBLIC_USERS_URI
ENV NEXT_PUBLIC_USERS_URI=$NEXT_PUBLIC_USERS_URI

ARG NEXT_PUBLIC_EVENTS_URI
ENV NEXT_PUBLIC_EVENTS_URI=$NEXT_PUBLIC_EVENTS_URI
#ARG NEXT_PUBLIC_USERS_API
#ARG NEXT_PUBLIC_EVENTS_API
#ARG NEXT_PUBLIC_POSTS_API
#ENV NEXT_PUBLIC_USERS_API=$NEXT_PUBLIC_USERS_API
#ENV NEXT_PUBLIC_EVENTS_API=$NEXT_PUBLIC_EVENTS_API
#ENV NEXT_PUBLIC_POSTS_API=$NEXT_PUBLIC_POSTS_API
COPY . .
RUN npm run build

# ===== RUN =====
FROM node:20-alpine
WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app/package.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/.next ./.next
COPY --from=build /app/public ./public
COPY --from=build /app/next.config.ts ./

EXPOSE 3000
CMD ["npm", "start"]
